# App
APP_NAME=HireMind
APP_ENV=development
API_PREFIX=/api/v1
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hiremind

# Redis (optional - for background jobs)
REDIS_URL=redis://localhost:6379/0

# ML Model
EMBEDDING_MODEL=all-MiniLM-L6-v2
SPACY_MODEL=en_core_web_sm

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/hiremind.log
